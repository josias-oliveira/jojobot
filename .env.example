# Configurações do Servidor
PORT=3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=seu_token_do_telegram_aqui

# APIs de Inteligência Artificial
GEMINI_API_KEY=sua_chave_do_gemini_aqui
OPENAI_API_KEY=sua_chave_da_openai_aqui

# LinkedIn API (Oficial)
LINKEDIN_ACCESS_TOKEN=seu_access_token_do_linkedin_aqui
LINKEDIN_MEMBER_URN=urn:li:person:seu_id_aqui

# Twitter/X API (via Tweepy em Python)
TWITTER_CONSUMER_KEY=sua_consumer_key_aqui
TWITTER_CONSUMER_SECRET=sua_consumer_secret_aqui
TWITTER_ACCESS_TOKEN=seu_access_token_aqui
TWITTER_ACCESS_TOKEN_SECRET=seu_access_token_secret_aqui
